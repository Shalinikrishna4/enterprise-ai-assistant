# ============================================================
# Enterprise AI Knowledge & Decision Assistant — Environment
# ============================================================

# Application
APP_NAME="Enterprise AI Knowledge Assistant"
APP_VERSION="1.0.0"
APP_ENV="production"
DEBUG=false
SECRET_KEY="your-super-secret-key-change-in-production"

# API Server
API_HOST="0.0.0.0"
API_PORT=8000
WORKERS=4
RELOAD=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_ai
POSTGRES_USER=enterprise_user
POSTGRES_PASSWORD=enterprise_pass
DATABASE_URL=postgresql+asyncpg://enterprise_user:enterprise_pass@postgres:5432/enterprise_ai

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# Vector Store
VECTOR_STORE_TYPE=chroma  # chroma | faiss
CHROMA_PERSIST_DIR=/app/data/chroma
FAISS_INDEX_DIR=/app/data/faiss
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
TOP_K_RETRIEVAL=5

# LLM Provider
LLM_PROVIDER=anthropic  # anthropic | openai | gemini
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
GEMINI_API_KEY=your-gemini-key
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# Chunking Strategy
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_SIZE=100

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
METRICS_PORT=9090

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,txt,json,csv,log
UPLOAD_DIR=/app/data/uploads

# Agent System
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120
MEMORY_WINDOW_SIZE=10

# Security
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=60
